{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "TerraformStateBucketList",
        "Effect": "Allow",
        "Action": "s3:ListBucket",
        "Resource": "arn:aws:s3:::nodejs-shopping-terraform-state"
      },
      {
        "Sid": "TerraformStateObjectsRW",
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject"
        ],
        "Resource": "arn:aws:s3:::nodejs-shopping-terraform-state/*"
      },
      {
        "Sid": "TerraformStateLocking",
        "Effect": "Allow",
        "Action": [
          "dynamodb:GetItem",
          "dynamodb:PutItem",
          "dynamodb:DeleteItem",
          "dynamodb:UpdateItem"
        ],
        "Resource": "arn:aws:dynamodb:us-west-1:471112626077:table/nodejs-shopping-terraform-locks"
      }
    ]
  }
  